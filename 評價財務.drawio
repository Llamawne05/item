        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    Start([main.py]) --&gt; Step1[第一步: split_pdf.py]\n    \n    subgraph Step1_Process [PDF 處理]\n        Step1 --&gt; S1_Upload[Gemini 辨識頁碼]\n        S1_Upload --&gt; S1_Check{辨識成功?}\n        S1_Check -- No --&gt; S1_Warn[記錄警告]\n        S1_Warn --&gt; S1_Skip[跳過該檔案]\n        S1_Check -- Yes --&gt; S1_Split[pypdf 拆分與合併]\n        S1_Split --&gt; S1_Out[輸出 PDF_new]\n    end\n\n    S1_Skip --&gt; Step2\n    S1_Out --&gt; Step2[第二步: gemini.py]\n\n    subgraph Step2_Process [數據擷取]\n        Step2 --&gt; S2_DB[查詢 Postgres 已處理清單]\n        S2_DB --&gt; S2_Filter{已存在?}\n        S2_Filter -- Yes --&gt; S2_Skip[跳過]\n        S2_Filter -- No --&gt; S2_Extract[Gemini 逐行擷取]\n        S2_Extract --&gt; S2_Format[整理統一欄位]\n        S2_Format --&gt; S2_Out[輸出 output/*.csv]\n    end\n\n    S2_Skip --&gt; Step3\n    S2_Out --&gt; Step3[第三步: csv_to_sql.py]\n\n    subgraph Step3_Process [清洗與入庫]\n        Step3 --&gt; S3_Check{有 CSV 檔?}\n        S3_Check -- No --&gt; Step4\n        S3_Check -- Yes --&gt; S3_Clean[清洗數據]\n        S3_Clean --&gt; S3_Delete[刪除舊資料]\n        S3_Delete --&gt; S3_Insert[寫入 fin_report.db]\n    end\n\n    S3_Insert --&gt; Step4[第四步: mapper.py]\n\n    subgraph Step4_Process [科目配碼]\n        Step4 --&gt; S4_Load[讀取 Excel 規則與 DB]\n        S4_Load --&gt; S4_Branch1[分支一: 根結點規則比對]\n        S4_Branch1 --&gt; S4_Logic{命中規則?}\n        S4_Logic -- Yes --&gt; S4_Sum[加總葉節點/歸戶]\n        S4_Logic -- No --&gt; S4_Branch2{USE_LLM_FALLBACK?}\n        S4_Branch2 -- Yes --&gt; S4_LLM[LLM 語意配對]\n        S4_Branch2 -- No --&gt; S4_Flag[標記待人工複核]\n        S4_Sum --&gt; S4_Out[輸出 JSON]\n        S4_LLM --&gt; S4_Out\n        S4_Flag --&gt; S4_Out\n    end\n\n    S4_Out --&gt; End([結束])\n    \n    style Step1 fill:#f9f,stroke:#333\n    style Step2 fill:#bbf,stroke:#333\n    style Step3 fill:#bfb,stroke:#333\n    style Step4 fill:#fbb,stroke:#333&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="nsriV6JWJuA5GTuS95Jt-1">
